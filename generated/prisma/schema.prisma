generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String            @id
  role              String            @default("student")
  email             String            @unique
  phone             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  emailVerifiedAt   DateTime?
  studentProfile    StudentProfile?
  alumniProfile     AlumniProfile?
  adminUser         AdminUser?
  bookingsAsStudent Booking[]         @relation("StudentBookings")
  paymentsVerified  Payment[]         @relation("VerifiedBy")
  savedAlumni       SavedAlumni[]
  notificationLogs  NotificationLog[]
}

model StudentProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  fullName     String
  dateOfBirth  DateTime?
  currentGrade String    @default("AS")
  school       String    @default("JBCN International School Borivali")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlumniProfile {
  id                    String                @id @default(cuid())
  userId                String                @unique
  fullName              String
  profilePhotoUrl       String?
  universityName        String
  course                String
  country               String
  graduationYearJbcn    Int
  currentStudyLevel     String                @default("undergraduate")
  qsRankingTier         String                @default("unranked")
  bio                   String?
  languages             String                @default("[]")
  linkedinUrl           String?
  verificationStatus    String                @default("pending")
  avgResponseTimeHours  Float?
  isVerifiedJbcnAlumnus Boolean               @default(false)
  isActive              Boolean               @default(true)
  ratingAvg             Float?
  ratingCount           Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability          AlumniAvailability[]
  sessionTypes          SessionTypeOffering[]
  bookings              Booking[]             @relation("AlumniBookings")
  groupSessions         GroupSession[]
  savedBy               SavedAlumni[]
  reviews               Review[]              @relation("AlumnusReviews")
}

model AlumniAvailability {
  id           String        @id @default(cuid())
  alumniId     String
  dayOfWeek    Int?
  specificDate DateTime?
  startTime    String
  endTime      String
  isRecurring  Boolean       @default(true)
  alumni       AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)
}

model SessionTypeOffering {
  id                  String         @id @default(cuid())
  alumniId            String
  type                String
  pricePaise          Int
  maxParticipants     Int            @default(1)
  descriptionOneLiner String?
  alumni              AlumniProfile  @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  groupSessions       GroupSession[]
}

model Booking {
  id                    String              @id @default(cuid())
  studentId             String
  alumniId              String
  sessionTypeOfferingId String
  status                String              @default("pending_payment")
  scheduledStartAt      DateTime
  scheduledEndAt        DateTime
  meetLink              String?
  groupSessionId        String?
  reminder24hSentAt     DateTime?
  reminder1hSentAt      DateTime?
  reviewPromptSentAt    DateTime?
  createdAt             DateTime            @default(now())
  student               User                @relation("StudentBookings", fields: [studentId], references: [id])
  alumni                AlumniProfile       @relation("AlumniBookings", fields: [alumniId], references: [id])
  sessionType           SessionTypeOffering @relation(fields: [sessionTypeOfferingId], references: [id])
  payment               Payment?
  groupSession          GroupSession?       @relation(fields: [groupSessionId], references: [id])
  review                Review?
}

model GroupSession {
  id                    String              @id @default(cuid())
  alumniId              String
  sessionTypeOfferingId String
  scheduledStartAt      DateTime
  maxParticipants       Int                 @default(6)
  currentParticipants   Int                 @default(0)
  status                String              @default("open")
  alumni                AlumniProfile       @relation(fields: [alumniId], references: [id])
  sessionType           SessionTypeOffering @relation(fields: [sessionTypeOfferingId], references: [id])
  bookings              Booking[]
}

model Payment {
  id                String    @id @default(cuid())
  bookingId         String    @unique
  amountPaise       Int
  upiTransactionRef String?
  status            String    @default("awaiting_ref")
  verifiedByAdminId String?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  booking           Booking   @relation(fields: [bookingId], references: [id])
  verifiedBy        User?     @relation("VerifiedBy", fields: [verifiedByAdminId], references: [id])
}

model Review {
  id               String         @id @default(cuid())
  bookingId        String         @unique
  reviewerType     String
  rating           Int
  text             String?
  moderationStatus String         @default("pending")
  createdAt        DateTime       @default(now())
  booking          Booking        @relation(fields: [bookingId], references: [id])
  alumnus          AlumniProfile? @relation("AlumnusReviews", fields: [alumnusId], references: [id])
  alumnusId        String?
}

model SavedAlumni {
  studentId String
  alumniId  String
  createdAt DateTime      @default(now())
  student   User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  alumni    AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@id([studentId, alumniId])
}

model PlatformStat {
  key              String   @id
  value            Int
  updatedAt        DateTime @updatedAt
  updatedByAdminId String?
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AdminUser {
  userId      String @id
  permissions String @default("all")
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  sentAt    DateTime @default(now())
  status    String   @default("logged")
  user      User     @relation(fields: [userId], references: [id])
}
